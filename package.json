{
  "name": "ad-automation-framework",
  "version": "1.0.0",
  "description": "Meta & Google Ads automation framework with OpenClaw integration, real-time React dashboard, and Slack/Telegram notifications",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run dashboard\"",
    "server": "node src/server.js",
    "dashboard": "cd src/dashboard && npx vite --port 3100",
    "collect": "node scripts/collect-data.js",
    "sync-campaigns": "node scripts/sync-campaigns.js",
    "setup": "node scripts/setup.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration.test.js",
    "test:load": "vitest run tests/load.test.js",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "facebook-nodejs-business-sdk": "^20.0.0",
    "google-ads-api": "^23.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
