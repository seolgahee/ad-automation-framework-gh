{
  "name": "ad-automation-framework",
  "version": "1.0.0",
  "description": "Meta & Google Ads automation framework with OpenClaw integration, real-time React dashboard, and Slack/Telegram notifications",
  "type": "module",
  "scripts": {
    "dev": "npm run server",
    "server": "node src/server.js",
    "collect": "node scripts/collect-data.js",
    "sync-campaigns": "node scripts/sync-campaigns.js",
    "setup": "node scripts/setup.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration.test.js",
    "test:load": "vitest run tests/load.test.js",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "facebook-nodejs-business-sdk": "^20.0.0",
    "google-ads-api": "^23.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "sharp": "^0.34.5",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
