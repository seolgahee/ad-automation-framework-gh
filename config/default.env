# ============================================================
# Ad Automation Framework — Environment Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# ---- Meta (Facebook) Marketing API ----
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_PIXEL_ID=your_pixel_id

# ---- Google Ads API ----
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=123-456-7890

# ---- OpenClaw Gateway ----
OPENCLAW_GATEWAY=ws://127.0.0.1:18789
OPENCLAW_WORKSPACE=ad-automation

# ---- Notification Channels ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ---- Server ----
API_PORT=3099
DASHBOARD_PORT=3100
DB_PATH=./data/ads.db

# ---- Data Collection ----
COLLECT_INTERVAL_MINUTES=15
ALERT_ROAS_THRESHOLD=1.5
ALERT_CPA_THRESHOLD=50000          # KRW (₩50,000)
ALERT_BUDGET_BURN_RATE=0.85

# ---- Authentication ----
API_AUTH_TOKEN=                     # Set a Bearer token to enable API auth (leave empty for dev mode)
